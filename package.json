{
  "name": "@szk302/tmms",
  "version": "0.1.1",
  "description": "Tmux Markdown Mailer System — async messaging between tmux panes via Markdown files",
  "type": "module",
  "bin": {
    "tmms": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "README_ja.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src tests",
    "format": "prettier --write src tests",
    "prepublishOnly": "pnpm test && pnpm build"
  },
  "keywords": [
    "tmux",
    "cli",
    "messaging",
    "markdown",
    "agent",
    "ipc",
    "ai-agent"
  ],
  "author": "szk302",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/szk302/tmms.git"
  },
  "homepage": "https://github.com/szk302/tmms#readme",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "gray-matter": "^4.0.3",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
